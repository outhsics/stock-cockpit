# Stock Cockpit 配置文件
# 拷贝为 .env 后填写：  cp .env.example .env

# ========== 安全（生产必改）==========
# JWT 签名密钥。生产环境务必改成随机长字符串，例如运行：
#   python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=please-change-me-to-a-random-64-char-hex-string

# ========== 默认管理员账户 ==========
# 首次启动时自动创建。留空 DEFAULT_ADMIN_PASSWORD 则每次启动随机生成并打印到日志。
DEFAULT_ADMIN_USERNAME=admin
DEFAULT_ADMIN_PASSWORD=

# ========== AI 简报（核心功能）==========
# 默认走智谱 GLM (Z.ai)，OpenAI 兼容协议。
# 获取 Key: 注册 https://open.bigmodel.cn 后在控制台创建 API Key
#
# 想换其他模型，改 PROVIDER 即可：
#   glm      -> 智谱 (默认，open.bigmodel.cn)
#   deepseek -> DeepSeek (api.deepseek.com)
#   openai   -> OpenAI (api.openai.com)
#   ollama   -> 本地 Ollama (localhost:11434，无需 Key)
#   custom   -> 自定义 LLM_BASE_URL
LLM_PROVIDER=glm
LLM_API_KEY=
LLM_BASE_URL=https://open.bigmodel.cn/api/paas/v4
LLM_MODEL=glm-4-flash
LLM_TEMPERATURE=0.6

# ========== 行情数据 ==========
# 推荐：申请免费 Alpha Vantage Key（稳定、不限容器 IP）
# 申请地址：https://www.alphavantage.co/support/#api-key （5分钟，免费）
# 留空则只用 Yahoo Finance 免费接口（在容器里经常被限流，不推荐生产用）
ALPHA_VANTAGE_API_KEY=

# ========== 定时任务（UTC 时间）==========
# 每日简报生成时间（默认 05:00 UTC ≈ 01:00 美东，美股收盘后）
BRIEFING_CRON_HOUR=5
BRIEFING_CRON_MINUTE=0
# 新闻自动刷新间隔（分钟）
NEWS_REFRESH_MINUTES=30

# ========== 调试 ==========
DEBUG=false
